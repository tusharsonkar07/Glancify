# ─── Newsdata.io ─────────────────────────────────────────────────────────────
# Get your free API key at https://newsdata.io/register
NEWSDATA_API_KEY=pub_cfe463f801d84770ace96761a9b92d2d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend URL (for CORS) ─────────────────────────────────────────────────
# Add your Vercel deployment URL here after deploying
FRONTEND_URL=https://glancify.vercel.app/

# ─── Cache settings (in minutes) ─────────────────────────────────────────────
# How long to cache each category before refetching from API
# 60 minutes = 7 categories × 24 refreshes = 168 credits/day
CACHE_TTL_MINUTES=60
# Top/breaking news refreshes faster
TOP_CACHE_TTL_MINUTES=20

# ─── Credit guard ────────────────────────────────────────────────────────────
# Stop making API calls when this many credits have been used today
DAILY_CREDIT_LIMIT=195
