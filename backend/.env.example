# ─── Newsdata.io API Keys ────────────────────────────────────────────────────
# Get free keys at https://newsdata.io/register (200 credits/day each)
# Add up to 3 keys — they rotate automatically when one is exhausted
NEWSDATA_API_KEY=pub_fa97e105b5674efdba127c7c3781171a
NEWSDATA_API_KEY_2=pub_72431b2ca10646dca24eca2ad74954e6
NEWSDATA_API_KEY_3=pub_3581333285014778af53efe88913e738   # uncomment to add a 3rd key

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend URL (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=https://glancify.vercel.app/

# ─── Cache settings (in minutes) ─────────────────────────────────────────────
# 60 min for categories, 20 min for "top" breaking news
CACHE_TTL_MINUTES=60
TOP_CACHE_TTL_MINUTES=20

# ─── Credit guard per key ─────────────────────────────────────────────────────
# Stop using a key after this many credits, then rotate to the next one
# Free tier = 200/day, keeping 10 buffer for searches
DAILY_CREDIT_LIMIT=190
